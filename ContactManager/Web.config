<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<system.diagnostics>
		<sources>
			<source name="EventLoggerSource" switchName="sourceSwitch" switchType="System.Diagnostics.SourceSwitch">
				<listeners>
					<remove name="Default" />
					<add name="EventLoggerListener" type="System.Diagnostics.EventLogTraceListener" initializeData="OutSystems Platform" />
				</listeners>
			</source>
		</sources>
		<switches>
			<add name="sourceSwitch" value="All" />
		</switches>
	</system.diagnostics>
	<system.xml.serialization>
		<dateTimeSerialization mode="Local" />
	</system.xml.serialization>
	<appSettings>
		<remove key="Installation.InstanceName" />
		<add key="Installation.InstanceName" value="DEFAULT" />
		<remove key="OutSystems.HubEdition.UnifiedEspaceKey" />
		<add key="OutSystems.HubEdition.UnifiedEspaceKey" value="794c445f-f27d-4f61-b47a-0da71440df68" />
		<remove key="OutSystems.RESTService.Assemblies" />
		<add key="OutSystems.RESTService.Assemblies" value="ContactManager" />
		<remove key="OutSystems.HubEdition.CacheInvalidationSuffix.794c445f-f27d-4f61-b47a-0da71440df68" />
		<add key="OutSystems.HubEdition.CacheInvalidationSuffix.794c445f-f27d-4f61-b47a-0da71440df68" value="?306" />
		<remove key="OutSystems.HubEdition.EspaceCompilationDate" />
		<add key="OutSystems.HubEdition.EspaceCompilationDate" value="638955371077500000" />
		<remove key="OutSystems.HubEdition.EspaceCompilationHash" />
		<add key="OutSystems.HubEdition.EspaceCompilationHash" value="dehrez7PR+oAoTAlCr7DVA" />
		<remove key="OutSystems.HubEdition.EspaceCompilationPlatformVersion" />
		<add key="OutSystems.HubEdition.EspaceCompilationPlatformVersion" value="11.35.0.45040" />
		<remove key="OutSystems.HubEdition.EspaceHMAC" />
		<add key="OutSystems.HubEdition.EspaceHMAC" value="aWbe57A3FXrLUWrQChep3o61d0E=" />
		<remove key="OutSystems.HubEdition.EspaceVersionID" />
		<add key="OutSystems.HubEdition.EspaceVersionID" value="306" />
		<remove key="OutSystems.Module.794c445f-f27d-4f61-b47a-0da71440df68.VersionId" />
		<add key="OutSystems.Module.794c445f-f27d-4f61-b47a-0da71440df68.VersionId" value="306" />
		<remove key="OutSystems.Security.ContentSecurityPolicy.ApplyCspRulesOnCompileTime" />
		<add key="OutSystems.Security.ContentSecurityPolicy.ApplyCspRulesOnCompileTime" value="True" />
		<remove key="OutSystems.Session.UseInMemorySession" />
		<add key="OutSystems.Session.UseInMemorySession" value="False" />
		<remove key="OutSystems.Module.PersonalAreaName" />
		<add key="OutSystems.Module.PersonalAreaName" value="" />
		<remove key="OutSystems.HubEdition.NoMARSSupport" />
		<add key="OutSystems.HubEdition.NoMARSSupport" value="True" />
	</appSettings>
	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="Newtonsoft.Json" culture="neutral" publicKeyToken="30ad4fe6b2a6aeed" />
				<bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="BouncyCastle.Crypto" culture="neutral" publicKeyToken="0e99375e54769942" />
				<bindingRedirect oldVersion="0.0.0.0-1.8.3.0" newVersion="1.8.3.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="Google.Protobuf" culture="neutral" publicKeyToken="a7d26565bac4d604" />
				<bindingRedirect oldVersion="0.0.0.0-3.6.1.0" newVersion="3.6.1.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="ICSharpCode.SharpZipLib" culture="neutral" publicKeyToken="1b03e6acf1164f73" />
				<bindingRedirect oldVersion="0.0.0.0-1.3.0.8" newVersion="1.3.0.8" />
			</dependentAssembly>
		</assemblyBinding>
	</runtime>
	<system.web>
		<trust level="Full" originUrl="" />
		<compilation defaultLanguage="c#" debug="true" batch="false" optimizeCompilations="true">
			<assemblies>
				<add assembly="netstandard, Version=2.0.0.0, Culture=neutral, PublicKeyToken=cc7b13ffcd2ddd51" />
			</assemblies>
		</compilation>
		<customErrors mode="RemoteOnly" defaultRedirect="/ContactManager/CustomHandlers/internalerror.aspx?">
			<error statusCode="404" redirect="/ContactManager/CustomHandlers/notfound.aspx?" />
		</customErrors>
		<authentication mode="None" />
		<identity impersonate="false" />
		<sessionState cookieless="false" regenerateExpiredSessionId="true" mode="Custom" customProvider="OutSystemsSessionProvider">
			<providers>
				<add name="OutSystemsSessionProvider" type="OutSystems.HubEdition.RuntimePlatform.SessionState.SqlSessionStateStore" />
			</providers>
		</sessionState>
		<pages enableSessionState="true" validateRequest="false" enableEventValidation="false" />
		<httpRuntime enableVersionHeader="false" useFullyQualifiedRedirectUrl="true" targetFramework="4.7.2" requestValidationMode="2.0" />
		<trace enabled="false" requestLimit="10" pageOutput="false" traceMode="SortByTime" localOnly="true" />
		<globalization requestEncoding="utf-8" responseEncoding="utf-8" />
		<httpModules>
			<add name="UnhandledExceptionModule" type="OutSystems.HubEdition.RuntimePlatform.UnhandledExceptionModule, OutSystems.HubEdition.RuntimePlatform" />
		</httpModules>
		<xhtmlConformance mode="Transitional" />
	</system.web>
	<system.webServer>
		<security>
			<requestFiltering>
				<hiddenSegments>
					<remove segment="bin2" />
					<add segment="bin2" />
					<remove segment="appSettings.config" />
					<add segment="appSettings.config" />
					<remove segment="appsettings.json" />
					<add segment="appsettings.json" />
				</hiddenSegments>
			</requestFiltering>
		</security>
		<defaultDocument enabled="true">
			<files>
				<clear />
				<add value="Home.aspx" />
			</files>
		</defaultDocument>
		<httpProtocol>
			<customHeaders>
				<remove name="X-Powered-By" />
				<remove name="X-Content-Type-Options" />
				<add name="X-Content-Type-Options" value="nosniff" />
			</customHeaders>
		</httpProtocol>
		<modules>
			<remove name="UnhandledExceptionModule" />
			<add name="UnhandledExceptionModule" type="OutSystems.HubEdition.RuntimePlatform.UnhandledExceptionModule, OutSystems.HubEdition.RuntimePlatform" preCondition="managedHandler" />
		</modules>
		<validation validateIntegratedModeConfiguration="false" />
	</system.webServer>
</configuration>